model ServiceQuote {
  id                     BigInt      @id @default(autoincrement())
  bookingId              BigInt      @map("booking_id")
  providerId             BigInt      @map("provider_id")
  diagnosis              String
  items                  Json
  laborCost              Decimal     @map("labor_cost") @db.Decimal(18, 2)
  partsCost              Decimal     @map("parts_cost") @db.Decimal(18, 2)
  totalCost              Decimal     @map("total_cost") @db.Decimal(18, 2)
  platformFee            Decimal     @map("platform_fee") @db.Decimal(18, 2)
  finalPrice             Decimal     @map("final_price") @db.Decimal(18, 2)
  warranty               String?     @db.VarChar(100)
  estimatedTime          Int?        @map("estimated_time")
  images                 String[]    @db.VarChar(500)
  notes                  String?
  status                 QuoteStatus @default(pending)
  createdAt              DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt              DateTime    @map("expires_at") @db.Timestamptz(6)
  acceptedAt             DateTime?   @map("accepted_at") @db.Timestamptz(6)
  surcharge              Decimal     @default(0) @db.Decimal(18, 2)
  providerNotes          String?     @map("provider_notes")
  hasChangesFromCustomer Boolean     @default(false) @map("has_changes_from_customer")
  quoteItems             QuoteItem[]
  booking                Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider               User        @relation("ProviderQuotes", fields: [providerId], references: [id])

  @@index([bookingId])
  @@index([providerId])
  @@index([status])
  @@map("service_quotes")
}

model QuoteItem {
  id                      BigInt               @id @default(autoincrement())
  quoteId                 BigInt               @map("quote_id")
  serviceItemId           BigInt?              @map("service_item_id")
  name                    String               @db.VarChar(200)
  description             String?
  unitPrice               Decimal              @map("unit_price") @db.Decimal(12, 2)
  quantity                Int                  @default(1)
  totalPrice              Decimal              @map("total_price") @db.Decimal(12, 2)
  isCustom                Boolean              @default(false) @map("is_custom")
  isFromCustomerSelection Boolean              @default(false) @map("is_from_customer")
  createdAt               DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  quote                   ServiceQuote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  serviceItem             ProviderServiceItem? @relation(fields: [serviceItemId], references: [id])

  @@index([quoteId])
  @@map("quote_items")
}

model BookingPayment {
  id             BigInt               @id @default(autoincrement())
  bookingId      BigInt               @unique @map("booking_id")
  customerId     BigInt               @map("customer_id")
  providerId     BigInt               @map("provider_id")
  amount         Decimal              @db.Decimal(18, 2)
  platformFee    Decimal              @map("platform_fee") @db.Decimal(18, 2)
  providerAmount Decimal              @map("provider_amount") @db.Decimal(18, 2)
  paymentMethod  String               @map("payment_method") @db.VarChar(20)
  momoTransId    String?              @map("momo_trans_id") @db.VarChar(100)
  status         BookingPaymentStatus @default(pending)
  paidAt         DateTime?            @map("paid_at") @db.Timestamptz(6)
  heldAt         DateTime?            @map("held_at") @db.Timestamptz(6)
  releasedAt     DateTime?            @map("released_at") @db.Timestamptz(6)
  refundedAt     DateTime?            @map("refunded_at") @db.Timestamptz(6)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  autoReleaseAt  DateTime?            @map("auto_release_at") @db.Timestamptz(6)
  disputeId      BigInt?              @map("dispute_id")
  refundAmount   Decimal?             @map("refund_amount") @db.Decimal(18, 2)
  refundReason   String?              @map("refund_reason")
  booking        Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer       User                 @relation("CustomerPayments", fields: [customerId], references: [id])
  provider       User                 @relation("ProviderPayments", fields: [providerId], references: [id])

  @@index([customerId])
  @@index([providerId])
  @@index([status])
  @@index([autoReleaseAt])
  @@map("booking_payments")
}

model Withdrawal {
  id          BigInt           @id @default(autoincrement())
  providerId  BigInt           @map("provider_id")
  amount      Decimal          @db.Decimal(18, 2)
  fee         Decimal          @default(0) @db.Decimal(18, 2)
  netAmount   Decimal          @map("net_amount") @db.Decimal(18, 2)
  method      String           @db.VarChar(20)
  bankName    String?          @map("bank_name") @db.VarChar(100)
  bankAccount String?          @map("bank_account") @db.VarChar(50)
  bankHolder  String?          @map("bank_holder") @db.VarChar(100)
  momoPhone   String?          @map("momo_phone") @db.VarChar(20)
  status      WithdrawalStatus @default(pending)
  note        String?
  adminNote   String?          @map("admin_note")
  processedBy BigInt?          @map("processed_by")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  processedAt DateTime?        @map("processed_at") @db.Timestamptz(6)
  admin       User?            @relation("AdminWithdrawals", fields: [processedBy], references: [id])
  provider    User             @relation("ProviderWithdrawals", fields: [providerId], references: [id])

  @@index([providerId])
  @@index([status])
  @@map("withdrawals")
}

model MinimumPrice {
  id           BigInt   @id @default(autoincrement())
  categoryCode String   @unique @map("category_code") @db.VarChar(50)
