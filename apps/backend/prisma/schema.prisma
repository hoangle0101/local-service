generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, postgis, uuid_ossp(map: "uuid-ossp", schema: "extensions")]
}

model User {
  id                    BigInt            @id @default(autoincrement())
  phone                 String            @unique @db.VarChar(20)
  email                 String?           @unique @db.VarChar(255)
  passwordHash          String?           @map("password_hash") @db.VarChar(255)
  status                UserStatus        @default(active)
  isVerified            Boolean           @default(false) @map("is_verified")
  lastLoginAt           DateTime?         @map("last_login_at") @db.Timestamptz(6)
  metadata              Json?
  deletedAt             DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  addresses             Address[]
  auditLogs             AuditLog[]
  bookingOffers         BookingOffer[]
  customerPayments      BookingPayment[]  @relation("CustomerPayments")
  providerPayments      BookingPayment[]  @relation("ProviderPayments")
  bookingsCustomer      Booking[]         @relation("CustomerBookings")
  bookingsProvider      Booking[]         @relation("ProviderBookings")
  conversationsCustomer Conversation[]    @relation("CustomerConversations")
  conversationsProvider Conversation[]    @relation("ProviderConversations")
  disputeEvidences      DisputeEvidence[]
  disputeTimelines      DisputeTimeline[]
  disputesRaised        Dispute[]         @relation("DisputeRaisedBy")
  disputesResolved      Dispute[]         @relation("DisputeResolvedBy")
  favorites             Favorite[]
  mediaUploads          Media[]
  sentMessages          Message[]
  notifications         Notification[]
  penaltiesCreated      Penalty[]         @relation("PenaltyCreatedBy")
  penaltiesReceived     Penalty[]         @relation("UserPenalties")
  providerProfile       ProviderProfile?
  reviewsReceived       Review[]          @relation("RevieweeReviews")
  reviewsGiven          Review[]          @relation("ReviewerReviews")
  serviceQuotes         ServiceQuote[]    @relation("ProviderQuotes")
  sessions              Session[]
  profile               UserProfile?
  userRoles             UserRole[]
  wallet                Wallet?
  adminWithdrawals      Withdrawal[]      @relation("AdminWithdrawals")
  providerWithdrawals   Withdrawal[]      @relation("ProviderWithdrawals")

  @@index([email])
  @@index([status])
  @@index([phone, status])
  @@map("users")
}

model UserProfile {
  userId      BigInt                    @id @map("user_id")
  fullName    String?                   @map("full_name") @db.VarChar(200)
  avatarUrl   String?                   @map("avatar_url")
  bio         String?
  gender      String?                   @db.VarChar(20)
  birthDate   DateTime?                 @map("birth_date") @db.Date
  addressText String?                   @map("address_text")
  location    Unsupported("geography")?
  createdAt   DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model OtpCode {
  id            BigInt     @id @default(autoincrement())
  phone         String     @db.VarChar(20)
  codeHash      String     @map("code_hash") @db.VarChar(255)
  purpose       OtpPurpose
  expiresAt     DateTime   @map("expires_at") @db.Timestamptz(6)
  used          Boolean    @default(false)
  attemptCount  Int        @default(0) @map("attempt_count") @db.SmallInt
  lastAttemptAt DateTime?  @map("last_attempt_at") @db.Timestamptz(6)
  ipAddress     String?    @map("ip_address") @db.VarChar(50)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([phone, purpose, used])
  @@map("otp_codes")
}

model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           BigInt    @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(255)
  userAgent        String?   @map("user_agent")
  ip               String?   @db.VarChar(50)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revoked          Boolean   @default(false)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([refreshTokenHash])
  @@map("sessions")
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique @db.VarChar(50)
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id              Int              @id @default(autoincrement())
  action          String           @unique @db.VarChar(100)
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    BigInt   @map("user_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model ProviderProfile {
  userId             BigInt                     @id @map("user_id")
  displayName        String                     @map("display_name") @db.VarChar(200)
  bio                String?
  skills             Json?
  ratingAvg          Decimal                    @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount        Int                        @default(0) @map("rating_count")
  isAvailable        Boolean                    @default(true) @map("is_available")
  verificationStatus ProviderVerificationStatus @default(unverified) @map("verification_status")
  location           Unsupported("geography")?
  address            String?
  latitude           Float?
  longitude          Float?
  serviceRadiusM     Int                        @default(5000) @map("service_radius_m")
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerServices   ProviderService[]

  @@index([isAvailable])
  @@index([verificationStatus])
  @@map("provider_profiles")
}

model ServiceCategory {
  id          Int               @id @default(autoincrement())
  code        String            @unique @db.VarChar(50)
  name        String            @db.VarChar(150)
  slug        String?           @unique @db.VarChar(150)
  description String?
  iconUrl     String?           @map("icon_url")
  parentId    Int?              @map("parent_id")
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  parent      ServiceCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ServiceCategory[] @relation("CategoryHierarchy")
  services    Service[]

  @@map("service_categories")
}

model Service {
  id               Int               @id @default(autoincrement())
  categoryId       Int?              @map("category_id")
  name             String            @db.VarChar(200)
  description      String?
  basePrice        Decimal           @default(0) @map("base_price") @db.Decimal(12, 2)
  durationMinutes  Int?              @map("duration_minutes")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  imageUrl         String?           @map("image_url")
  isActive         Boolean           @default(true) @map("is_active")
  bookings         Booking[]
  providerServices ProviderService[]
  category         ServiceCategory?  @relation(fields: [categoryId], references: [id])

  @@map("services")
}

model ProviderService {
  providerUserId BigInt                @map("provider_user_id")
  serviceId      Int                   @map("service_id")
  price          Decimal               @db.Decimal(12, 2)
  currency       String                @default("VND") @db.VarChar(10)
  isActive       Boolean               @default(true) @map("is_active")
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?             @map("deleted_at") @db.Timestamptz(6)
  items          ProviderServiceItem[]
  provider       ProviderProfile       @relation(fields: [providerUserId], references: [userId], onDelete: Cascade)
  service        Service               @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([providerUserId, serviceId])
  @@map("provider_services")
}

model ProviderServiceItem {
  id                   BigInt                @id @default(autoincrement())
  providerUserId       BigInt                @map("provider_user_id")
  serviceId            Int                   @map("service_id")
  name                 String                @db.VarChar(200)
  description          String?
  price                Decimal               @db.Decimal(12, 2)
  imageUrl             String?               @map("image_url")
  isActive             Boolean               @default(true) @map("is_active")
  sortOrder            Int                   @default(0) @map("sort_order")
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  bookingSelectedItems BookingSelectedItem[]
  providerService      ProviderService       @relation(fields: [providerUserId, serviceId], references: [providerUserId, serviceId], onDelete: Cascade)
  quoteItems           QuoteItem[]

  @@index([providerUserId, serviceId])
  @@map("provider_service_items")
}

model Favorite {
  userId     BigInt   @map("user_id")
  targetType String   @map("target_type") @db.VarChar(20)
  targetId   BigInt   @map("target_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, targetType, targetId])
  @@map("favorites")
}

model Address {
  id          BigInt                   @id @default(autoincrement())
  userId      BigInt                   @map("user_id")
  label       String?                  @db.VarChar(100)
  addressText String                   @map("address_text")
  location    Unsupported("geography")
  isDefault   Boolean                  @default(false) @map("is_default")
  createdAt   DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Booking {
  id                       BigInt                   @id @default(autoincrement())
  code                     String?                  @unique @db.VarChar(50)
  customerId               BigInt                   @map("customer_id")
  providerId               BigInt?                  @map("provider_id")
  serviceId                Int                      @map("service_id")
  providerServicePrice     Decimal?                 @map("provider_service_price") @db.Decimal(12, 2)
  status                   BookingStatus            @default(pending)
  scheduledAt              DateTime                 @map("scheduled_at") @db.Timestamptz(6)
  addressText              String                   @map("address_text")
  location                 Unsupported("geography")
  notes                    String?
  estimatedDurationMinutes Int?                     @map("estimated_duration_minutes")
  estimatedPrice           Decimal?                 @map("estimated_price") @db.Decimal(12, 2)
  actualPrice              Decimal?                 @map("actual_price") @db.Decimal(12, 2)
  additionalCosts          Decimal?                 @map("additional_costs") @db.Decimal(12, 2)
  additionalNotes          String?                  @map("additional_notes")
  platformFee              Decimal                  @default(0) @map("platform_fee") @db.Decimal(12, 2)
  providerEarning          Decimal                  @default(0) @map("provider_earning") @db.Decimal(12, 2)
  paymentMethod            PaymentMethod?           @map("payment_method")
  paymentStatus            String                   @default("unpaid") @map("payment_status") @db.VarChar(20)
  createdAt                DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  completedAt              DateTime?                @map("completed_at") @db.Timestamptz(6)
  cancelledAt              DateTime?                @map("cancelled_at") @db.Timestamptz(6)
  paidAt                   DateTime?                @map("paid_at") @db.Timestamptz(6)
  bookingEvents            BookingEvent[]
  bookingOffers            BookingOffer[]
  bookingPayment           BookingPayment?
  selectedItems            BookingSelectedItem[]
  customer                 User                     @relation("CustomerBookings", fields: [customerId], references: [id])
  providerUser             User?                    @relation("ProviderBookings", fields: [providerId], references: [id], onDelete: Restrict)
  service                  Service                  @relation(fields: [serviceId], references: [id])
  conversations            Conversation[]
  dispute                  Dispute?
  payments                 Payment[]
  review                   Review?
  serviceQuotes            ServiceQuote[]

  @@index([customerId, status])
  @@index([providerId, status])
  @@index([scheduledAt])
  @@index([status, scheduledAt])
  @@map("bookings")
}

model BookingSelectedItem {
  id                    BigInt              @id @default(autoincrement())
  bookingId             BigInt              @map("booking_id")
  providerServiceItemId BigInt              @map("provider_service_item_id")
  quantity              Int                 @default(1)
  unitPrice             Decimal             @map("unit_price") @db.Decimal(12, 2)
  totalPrice            Decimal             @map("total_price") @db.Decimal(12, 2)
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  booking               Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  providerServiceItem   ProviderServiceItem @relation(fields: [providerServiceItemId], references: [id])

  @@unique([bookingId, providerServiceItemId])
  @@index([bookingId])
  @@index([bookingId], map: "idx_booking_selected_items_booking_id")
  @@map("booking_selected_items")
}

model BookingOffer {
  id         BigInt   @id @default(autoincrement())
  bookingId  BigInt   @map("booking_id")
  providerId BigInt   @map("provider_id")
  price      Decimal? @db.Decimal(12, 2)
  status     String   @default("PENDING")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider   User     @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([bookingId, providerId])
  @@map("booking_offers")
}

model BookingEvent {
  id             BigInt         @id @default(autoincrement())
  bookingId      BigInt         @map("booking_id")
  previousStatus BookingStatus? @map("previous_status")
  newStatus      BookingStatus  @map("new_status")
  actorUserId    BigInt?        @map("actor_user_id")
  note           String?
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  booking        Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt(sort: Desc)])
  @@map("booking_events")
}

model Payment {
  id                 BigInt              @id @default(autoincrement())
  bookingId          BigInt?             @map("booking_id")
  amount             Decimal             @db.Decimal(15, 2)
  currency           String              @default("VND") @db.VarChar(10)
  method             PaymentMethod
  gateway            String?             @db.VarChar(100)
  gatewayTxId        String              @map("gateway_tx_id") @db.VarChar(200)
  environment        String              @default("production") @db.VarChar(20)
  status             PaymentStatus       @default(initiated)
  payload            Json?
  reconciled         Boolean             @default(false)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  booking            Booking?            @relation(fields: [bookingId], references: [id])
  walletTransactions WalletTransaction[]

  @@unique([gateway, gatewayTxId, environment])
  @@index([bookingId])
  @@index([status])
  @@map("payments")
}

model Wallet {
  userId         BigInt              @id @map("user_id")
  balance        Decimal             @default(0) @db.Decimal(18, 4)
  currency       String              @default("VND") @db.VarChar(10)
  version        Int                 @default(0)
  lockedUntil    DateTime?           @map("locked_until") @db.Timestamptz(6)
  lockedBy       String?             @map("locked_by") @db.VarChar(100)
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  lockedBalance  Decimal             @default(0) @map("locked_balance") @db.Decimal(18, 4)
  minimumBalance Decimal             @default(500000) @map("minimum_balance") @db.Decimal(18, 4)
  transactions   WalletTransaction[]
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model WalletTransaction {
  id               BigInt            @id @default(autoincrement())
  walletUserId     BigInt            @map("wallet_user_id")
  relatedPaymentId BigInt?           @map("related_payment_id")
  type             TransactionType
  amount           Decimal           @db.Decimal(18, 4)
  balanceAfter     Decimal           @map("balance_after") @db.Decimal(18, 4)
  idempotencyKey   String?           @unique @map("idempotency_key") @db.VarChar(100)
  status           TransactionStatus @default(completed)
  metadata         Json?
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  payment          Payment?          @relation(fields: [relatedPaymentId], references: [id])
  wallet           Wallet            @relation(fields: [walletUserId], references: [userId])

  @@index([walletUserId, createdAt(sort: Desc)])
  @@index([type])
  @@index([relatedPaymentId])
  @@map("wallet_transactions")
}

model Review {
  id         BigInt   @id @default(autoincrement())
  bookingId  BigInt   @unique @map("booking_id")
  reviewerId BigInt   @map("reviewer_id")
  revieweeId BigInt   @map("reviewee_id")
  rating     Int      @db.SmallInt
  title      String?  @db.VarChar(255)
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewee   User     @relation("RevieweeReviews", fields: [revieweeId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([revieweeId, rating])
  @@index([revieweeId, createdAt(sort: Desc)])
  @@index([reviewerId])
  @@map("reviews")
}

model Dispute {
  id                BigInt                 @id @default(autoincrement())
  bookingId         BigInt                 @unique @map("booking_id")
  raisedBy          BigInt                 @map("raised_by")
  reason            String
  status            DisputeStatus          @default(open)
  resolution        String?
  resolvedByAdminId BigInt?                @map("resolved_by_admin_id")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt        DateTime?              @map("resolved_at") @db.Timestamptz(6)
  adminNotes        String?                @map("admin_notes")
  appealCount       Int                    @default(0) @map("appeal_count")
  category          DisputeCategory        @default(other)
  escalatedAt       DateTime?              @map("escalated_at") @db.Timestamptz(6)
  lastAppealAt      DateTime?              @map("last_appeal_at") @db.Timestamptz(6)
  refundAmount      Decimal?               @map("refund_amount") @db.Decimal(15, 2)
  resolutionType    DisputeResolutionType? @map("resolution_type")
  respondedAt       DateTime?              @map("responded_at") @db.Timestamptz(6)
  evidence          DisputeEvidence[]
  timeline          DisputeTimeline[]
  booking           Booking                @relation(fields: [bookingId], references: [id])
  raiser            User                   @relation("DisputeRaisedBy", fields: [raisedBy], references: [id])
  resolvedBy        User?                  @relation("DisputeResolvedBy", fields: [resolvedByAdminId], references: [id])
  penalties         Penalty[]

  @@index([status])
  @@index([category])
  @@index([createdAt(sort: Desc)])
  @@map("disputes")
}

model DisputeTimeline {
  id          BigInt   @id @default(autoincrement())
  disputeId   BigInt   @map("dispute_id")
  action      String   @db.VarChar(50)
  description String
  actorUserId BigInt?  @map("actor_user_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actor       User?    @relation(fields: [actorUserId], references: [id])
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@map("dispute_timeline")
}

model DisputeEvidence {
  id          BigInt       @id @default(autoincrement())
  disputeId   BigInt       @map("dispute_id")
  uploaderId  BigInt       @map("uploader_id")
  type        EvidenceType
  url         String       @db.VarChar(500)
  description String?
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  dispute     Dispute      @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  uploader    User         @relation(fields: [uploaderId], references: [id])

  @@index([disputeId])
  @@map("dispute_evidence")
}

model Penalty {
  id               BigInt          @id @default(autoincrement())
  userId           BigInt          @map("user_id")
  disputeId        BigInt?         @map("dispute_id")
  type             PenaltyType
  severity         PenaltySeverity
  reason           String
  amount           Decimal?        @db.Decimal(15, 2)
  expiresAt        DateTime?       @map("expires_at") @db.Timestamptz(6)
  isActive         Boolean         @default(true) @map("is_active")
  createdByAdminId BigInt          @map("created_by_admin_id")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy        User            @relation("PenaltyCreatedBy", fields: [createdByAdminId], references: [id])
  dispute          Dispute?        @relation(fields: [disputeId], references: [id])
  user             User            @relation("UserPenalties", fields: [userId], references: [id])

  @@index([userId])
  @@index([disputeId])
  @@index([isActive])
  @@map("penalties")
}

model Conversation {
  id            BigInt    @id @default(autoincrement())
  customerId    BigInt    @map("customer_id")
  providerId    BigInt    @map("provider_id")
  bookingId     BigInt?   @map("booking_id")
  lastMessageId BigInt?   @map("last_message_id")
  lastMessageAt DateTime? @map("last_message_at") @db.Timestamptz(6)
  unreadCount   Int       @default(0) @map("unread_count")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  booking       Booking?  @relation(fields: [bookingId], references: [id])
  customer      User      @relation("CustomerConversations", fields: [customerId], references: [id], onDelete: Cascade)
  provider      User      @relation("ProviderConversations", fields: [providerId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([customerId])
  @@index([providerId])
  @@index([bookingId])
  @@map("conversations")
}

model Message {
  id             BigInt       @id @default(autoincrement())
  conversationId BigInt       @map("conversation_id")
  senderId       BigInt       @map("sender_id")
  body           String
  readAt         DateTime?    @map("read_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("messages")
}

model Media {
  id         BigInt    @id @default(autoincrement())
  ownerType  String    @map("owner_type") @db.VarChar(50)
  ownerId    BigInt    @map("owner_id")
  url        String
  mimeType   String?   @map("mime_type") @db.VarChar(100)
  size       Int?
  meta       Json?
  uploadedBy BigInt?   @map("uploaded_by")
  category   String?   @db.VarChar(50)
  isPublic   Boolean   @default(true) @map("is_public")
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  uploader   User?     @relation(fields: [uploadedBy], references: [id])

  @@index([ownerType, ownerId])
  @@index([uploadedBy])
  @@index([ownerType, category])
  @@map("media")
}

model Notification {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @map("user_id")
  type        String    @db.VarChar(100)
  title       String?
  body        String?
  payload     Json?
  isRead      Boolean   @default(false) @map("is_read")
  sentAt      DateTime? @map("sent_at") @db.Timestamptz(6)
  deliveredAt DateTime? @map("delivered_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model AuditLog {
