          "event": [{
            "listen": "test",
            "script": {"exec": ["console.log('✅ User registered. Check console for OTP code!');"]}
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+84999111222\",\n  \"password\": \"Customer123!@#\",\n  \"fullName\": \"Nguyen Van Customer\"\n}"
            },
            "url": {"raw": "{{BASE_URL}}/auth/register", "host": ["{{BASE_URL}}"], "path": ["auth", "register"]}
          }
